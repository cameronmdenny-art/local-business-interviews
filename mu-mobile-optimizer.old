<?php
/**
 * Plugin Name: Cairde Mobile Optimizer
 * Description: Global mobile-first optimization for Cairde + Local Business Interviews pages.
 * Version: 1.0.0
 */

if (!defined('ABSPATH')) {
    exit;
}

add_action('wp_head', function () {
    if (is_admin()) {
        return;
    }
    ?>
    <style id="cairde-mobile-optimizer">
        html, body {
            max-width: 100%;
            overflow-x: hidden;
        }

        img, video, iframe {
            max-width: 100%;
            height: auto;
        }

        .lbi-container,
        .lbi-directory-shell,
        .site-main,
        .entry-content {
            width: 100%;
            max-width: 100%;
        }

        .lbi-post-content,
        .entry-content {
            word-wrap: break-word;
            overflow-wrap: anywhere;
        }

        table {
            display: block;
            width: 100%;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        input,
        select,
        textarea,
        button,
        .button,
        .wp-element-button,
        a.lbi-btn,
        .cd-btn,
        .cd-top-btn {
            font-size: 16px;
            min-height: 44px;
        }

        @media (max-width: 1024px) {
            .lbi-directory-app .lbi-directory-results-wrap,
            .lbi-directory-results-wrap {
                grid-template-columns: 1fr !important;
                gap: 14px !important;
            }

            .lbi-directory-app .lbi-map-panel,
            .lbi-map-panel {
                position: static !important;
                top: auto !important;
            }

            #lbi-directory-map,
            .lbi-directory-map {
                min-height: 340px !important;
            }
        }

        @media (max-width: 768px) {
            body {
                -webkit-text-size-adjust: 100%;
            }

            .lbi-container,
            .lbi-directory-shell {
                padding-left: 14px !important;
                padding-right: 14px !important;
            }

            .lbi-section {
                padding: 44px 14px !important;
            }

            .lbi-hero {
                min-height: auto !important;
                padding: 96px 14px 48px !important;
            }

            .lbi-hero-content {
                padding: 0.5rem !important;
            }

            .lbi-hero h1 {
                font-size: clamp(1.8rem, 8.5vw, 2.3rem) !important;
                line-height: 1.12 !important;
                letter-spacing: -0.02em !important;
            }

            .lbi-hero p {
                font-size: 1rem !important;
                margin-bottom: 1.3rem !important;
            }

            .lbi-hero-buttons,
            .lbi-form-row,
            .lbi-directory-filter-form,
            .lbi-filter-actions,
            .lbi-directory-card-actions,
            .lbi-share-buttons,
            .footer-bottom,
            .footer-legal {
                display: flex !important;
                flex-direction: column !important;
                gap: 10px !important;
                width: 100% !important;
            }

            .lbi-btn,
            .lbi-btn-primary,
            .lbi-btn-ghost,
            .lbi-search-btn,
            .lbi-filter-btn,
            .lbi-submit-btn,
            .lbi-share-btn,
            .cd-top-btn,
            .cd-btn {
                width: 100% !important;
                justify-content: center !important;
                text-align: center !important;
                padding: 12px 14px !important;
            }

            .lbi-grid,
            .lbi-posts-grid,
            .lbi-category-grid,
            .lbi-checkbox-group {
                grid-template-columns: 1fr !important;
                gap: 14px !important;
            }

            .lbi-card,
            .lbi-post-card,
            .lbi-directory-card,
            .lbi-results-list,
            .lbi-map-panel,
            .lbi-directory-controls,
            .lbi-form {
                border-radius: 12px !important;
            }

            .lbi-card-content,
            .lbi-post-content,
            .lbi-form fieldset {
                padding: 18px !important;
            }

            .lbi-directory-card-title,
            .lbi-post-title,
            .lbi-card-title {
                font-size: 1.25rem !important;
                line-height: 1.25 !important;
            }

            .lbi-directory-app .lbi-directory-title {
                font-size: clamp(1.7rem, 9vw, 2.2rem) !important;
                line-height: 1.1 !important;
            }

            .lbi-directory-app .lbi-directory-subtitle {
                font-size: 0.95rem !important;
            }

            .lbi-directory-app .lbi-directory-filter-form {
                grid-template-columns: 1fr !important;
                align-items: stretch !important;
            }

            .lbi-directory-app .lbi-filter-field input,
            .lbi-directory-app .lbi-filter-field select,
            #lbi-business-name,
            #lbi-location,
            #lbi-business-category {
                height: 46px !important;
                font-size: 16px !important;
            }

            .lbi-directory-app .lbi-category-chip {
                min-height: 44px !important;
                padding: 12px !important;
            }

            .lbi-directory-app .lbi-directory-map,
            #lbi-directory-map {
                min-height: 300px !important;
            }

            .lbi-breadcrumbs {
                font-size: 0.85rem !important;
                line-height: 1.45 !important;
                word-break: break-word;
            }

            .lbi-directory-details {
                display: grid !important;
                grid-template-columns: 1fr !important;
                gap: 14px !important;
            }

            .lbi-contact-section,
            .lbi-additional-section,
            .lbi-contact-info,
            .lbi-video-container,
            .lbi-related-posts {
                padding: 14px !important;
                border-radius: 12px !important;
            }

            #cdTopNavInner {
                padding: 10px 12px !important;
            }

            #cdTopLinks {
                width: 100% !important;
                display: grid !important;
                grid-template-columns: repeat(3, minmax(0, 1fr));
                gap: 8px !important;
            }

            #cdTopBrand {
                font-size: 0.95rem !important;
            }

            #cdHeroTitle {
                font-size: clamp(1.8rem, 10vw, 2.4rem) !important;
            }

            #cdHeroButtons {
                gap: 0.65rem !important;
            }

            #cairde-footer-container {
                padding: 42px 14px !important;
                margin-top: 44px !important;
            }
        }

        @media (max-width: 480px) {
            .lbi-hero {
                padding-top: 88px !important;
            }

            .lbi-hero h1 {
                font-size: clamp(1.6rem, 9.5vw, 2rem) !important;
            }

            .lbi-section-header p,
            .lbi-card-excerpt,
            .lbi-post-excerpt,
            .lbi-directory-card-location,
            .lbi-directory-card-address,
            .lbi-directory-card-phone {
                font-size: 0.95rem !important;
            }

            .lbi-pagination .page-numbers {
                margin: 0 4px 8px 0 !important;
                padding: 8px 10px !important;
                min-width: 36px;
                text-align: center;
            }

            #cdTopLinks {
                grid-template-columns: 1fr !important;
            }
        }

        @media (hover: none) and (pointer: coarse) {
            .lbi-card:hover,
            .cd-btn:hover,
            .cd-top-btn:hover,
            .lbi-btn:hover,
            .lbi-btn-primary:hover,
            .lbi-btn-ghost:hover {
                transform: none !important;
                box-shadow: none !important;
            }
        }
    </style>
    <?php
}, 1000);
