<?php
/**
 * Plugin Name: Cairde Forms Optimizer
 * Description: Premium form styling with gold accents for Cairde Designs
 * Version: 1.0.0
 * Author: Cairde Designs
 */

if (!defined('ABSPATH')) {
    exit;
}

add_action('wp_head', 'cairde_inject_form_styles', 999);

function cairde_inject_form_styles() {
    ?>
    <style>
        /* Form Container Styling */
        .lbi-form-container,
        form.lbi-form,
        .wp-block-contact-form-7,
        .wpcf7,
        .gform_wrapper {
            background: #ffffff;
            border: 1px solid rgba(176, 138, 60, 0.15);
            border-radius: 16px;
            padding: 40px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.05);
            transition: all 0.34s cubic-bezier(0.22, 1, 0.36, 1);
        }
        
        .lbi-form-container:hover,
        form.lbi-form:hover,
        .wpcf7:hover {
            box-shadow: 0 15px 50px rgba(176, 138, 60, 0.12);
            transform: translateY(-2px);
        }
        
        /* Form Headings */
        .lbi-form-container h2,
        .lbi-form-container h3,
        form.lbi-form h2,
        form.lbi-form h3 {
            color: #111111;
            margin-bottom: 1.5rem;
            font-weight: 800;
        }
        
        .lbi-form-container h2 .gold,
        form.lbi-form h2 .gold {
            color: #b08a3c;
        }
        
        /* Input Fields */
        input[type="text"],
        input[type="email"],
        input[type="url"],
        input[type="tel"],
        input[type="number"],
        input[type="date"],
        textarea,
        select {
            width: 100%;
            padding: 14px 18px;
            border: 2px solid #e8e8e8;
            border-radius: 10px;
            font-size: 15px;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            color: #111111;
            background: #ffffff;
            transition: all 0.26s cubic-bezier(0.22, 1, 0.36, 1);
            outline: none;
        }
        
        input[type="text"]:focus,
        input[type="email"]:focus,
        input[type="url"]:focus,
        input[type="tel"]:focus,
        input[type="number"]:focus,
        input[type="date"]:focus,
        textarea:focus,
        select:focus {
            border-color: #b08a3c;
            box-shadow: 0 0 0 3px rgba(176, 138, 60, 0.1);
            transform: translateY(-1px);
        }
        
        /* Textarea */
        textarea {
            min-height: 140px;
            resize: vertical;
        }
        
        /* Labels */
        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            font-size: 14px;
            color: #333333;
            letter-spacing: 0.3px;
        }
        
        /* Submit Buttons */
        input[type="submit"],
        button[type="submit"],
        .lbi-submit-btn,
        .wpcf7-submit,
        .gform_button {
            background: linear-gradient(145deg, #c8a25b 0%, #a57b2f 100%);
            color: #ffffff;
            border: 2px solid #a57b2f;
            padding: 14px 36px;
            border-radius: 999px;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            transition: all 0.34s cubic-bezier(0.22, 1, 0.36, 1);
            box-shadow: 0 8px 20px rgba(176, 138, 60, 0.3);
            position: relative;
            overflow: hidden;
        }
        
        input[type="submit"]::before,
        button[type="submit"]::before,
        .lbi-submit-btn::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, rgba(255, 255, 255, 0) 30%, rgba(255, 255, 255, 0.3) 50%, rgba(255, 255, 255, 0) 70%);
            transform: translateX(-100%);
            transition: transform 0.85s cubic-bezier(0.22, 1, 0.36, 1);
        }
        
        input[type="submit"]:hover,
        button[type="submit"]:hover,
        .lbi-submit-btn:hover,
        .wpcf7-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 30px rgba(176, 138, 60, 0.4);
            background: linear-gradient(145deg, #d4ae6b 0%, #b58935 100%);
        }
        
        input[type="submit"]:hover::before,
        button[type="submit"]:hover::before,
        .lbi-submit-btn:hover::before {
            transform: translateX(100%);
        }
        
        /* Form Fields Wrapper */
        .form-field,
        .lbi-field,
        .wpcf7-form-control-wrap {
            margin-bottom: 24px;
        }
        
        /* Required Field Indicator */
        .required,
        abbr[title="required"] {
            color: #b08a3c;
            text-decoration: none;
        }
        
        /* Success/Error Messages */
        .wpcf7-response-output,
        .lbi-form-message,
        .gform_confirmation_message {
            padding: 16px 20px;
            border-radius: 10px;
            margin-top: 20px;
            font-size: 14px;
            font-weight: 600;
        }
        
        .wpcf7-mail-sent-ok,
        .lbi-form-message.success {
            background: rgba(176, 138, 60, 0.1);
            border: 2px solid #b08a3c;
            color: #6b5424;
        }
        
        .wpcf7-validation-errors,
        .lbi-form-message.error {
            background: rgba(220, 53, 69, 0.1);
            border: 2px solid #dc3545;
            color: #721c24;
        }
        
        /* Checkbox & Radio Styling */
        input[type="checkbox"],
        input[type="radio"] {
            width: 20px;
            height: 20px;
            margin-right: 10px;
            accent-color: #b08a3c;
            cursor: pointer;
        }
        
        /* File Upload Styling */
        input[type="file"] {
            padding: 10px;
            border: 2px dashed #e8e8e8;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.26s ease;
        }
        
        input[type="file"]:hover {
            border-color: #b08a3c;
            background: rgba(176, 138, 60, 0.02);
        }
        
        /* Placeholder Styling */
        ::placeholder {
            color: #999999;
            opacity: 1;
        }
        
        /* Mobile Responsiveness */
        @media (max-width: 768px) {
            .lbi-form-container,
            form.lbi-form,
            .wpcf7 {
                padding: 30px 20px;
            }
            
            input[type="submit"],
            button[type="submit"],
            .lbi-submit-btn {
                width: 100%;
                padding: 16px 24px;
            }
        }
        
        /* Animation for form appearance */
        @keyframes formFadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .lbi-form-container,
        form.lbi-form {
            animation: formFadeIn 0.6s ease-out;
        }
    </style>
    <?php
}
