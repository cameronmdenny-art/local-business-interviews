<?php
/**
 * Plugin Name: Cairde Directory Enhancer
 * Description: Premium directory styling with gold accents and luxury feel
 * Version: 1.0.0
 * Author: Cairde Designs
 */

if (!defined('ABSPATH')) {
    exit;
}

add_action('wp_head', 'cairde_inject_directory_styles', 999);

function cairde_inject_directory_styles() {
    ?>
    <style>
        /* Directory Page Styling */
        .lbi-directory-page,
        .post-type-archive-directory {
            background: #fafafa;
        }
        
        /* Directory Header */
        .lbi-directory-header {
            background: linear-gradient(135deg, #ffffff 0%, #faf9f7 100%);
            padding: 80px 20px 60px;
            text-align: center;
            border-bottom: 1px solid rgba(176, 138, 60, 0.15);
            margin-bottom: 60px;
            position: relative;
            overflow: hidden;
        }
        
        .lbi-directory-header::before {
            content: "";
            position: absolute;
            width: 500px;
            height: 500px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(176, 138, 60, 0.08) 0%, transparent 70%);
            top: -200px;
            left: 50%;
            transform: translateX(-50%);
            animation: headerPulse 8s ease-in-out infinite;
        }
        
        .lbi-directory-header h1 {
            font-size: clamp(2.5rem, 5vw, 3.5rem);
            font-weight: 800;
            color: #111111;
            margin: 0 0 20px 0;
            letter-spacing: -0.02em;
            position: relative;
            z-index: 1;
        }
        
        .lbi-directory-header h1 .gold {
            color: #b08a3c;
        }
        
        .lbi-directory-header p {
            font-size: 1.15rem;
            color: #444444;
            max-width: 700px;
            margin: 0 auto;
            line-height: 1.7;
            position: relative;
            z-index: 1;
        }
        
        /* Directory Grid */
        .lbi-directory-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 32px;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px 80px;
        }
        
        /* Business Card */
        .lbi-business-card {
            background: #ffffff;
            border: 1px solid rgba(176, 138, 60, 0.12);
            border-radius: 16px;
            padding: 32px;
            transition: all 0.34s cubic-bezier(0.22, 1, 0.36, 1);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
            position: relative;
            overflow: hidden;
        }
        
        .lbi-business-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #c8a25b 0%, #a57b2f 100%);
            transform: scaleX(0);
            transform-origin: left;
            transition: transform 0.34s cubic-bezier(0.22, 1, 0.36, 1);
        }
        
        .lbi-business-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 40px rgba(176, 138, 60, 0.15);
            border-color: #b08a3c;
        }
        
        .lbi-business-card:hover::before {
            transform: scaleX(1);
        }
        
        .lbi-business-card h3 {
            font-size: 1.5rem;
            font-weight: 700;
            color: #111111;
            margin: 0 0 12px 0;
            letter-spacing: -0.01em;
        }
        
        .lbi-business-card h3 a {
            color: #111111;
            text-decoration: none;
            transition: color 0.26s ease;
        }
        
        .lbi-business-card h3 a:hover {
            color: #b08a3c;
        }
        
        .lbi-business-category {
            display: inline-block;
            background: rgba(176, 138, 60, 0.1);
            color: #8a6a2e;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 0.80rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 16px;
        }
        
        .lbi-business-description {
            color: #555555;
            font-size: 0.95rem;
            line-height: 1.7;
            margin-bottom: 20px;
        }
        
        .lbi-business-meta {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            font-size: 0.90rem;
            color: #777777;
            padding-top: 16px;
            border-top: 1px solid #f0f0f0;
        }
        
        .lbi-business-meta span {
            display: flex;
            align-items: center;
            gap: 6px;
        }
        
        .lbi-business-cta {
            display: inline-block;
            background: linear-gradient(145deg, #c8a25b 0%, #a57b2f 100%);
            color: #ffffff;
            padding: 10px 24px;
            border-radius: 999px;
            font-weight: 600;
            font-size: 0.90rem;
            text-decoration: none;
            margin-top: 16px;
            transition: all 0.26s cubic-bezier(0.22, 1, 0.36, 1);
            box-shadow: 0 4px 12px rgba(176, 138, 60, 0.25);
        }
        
        .lbi-business-cta:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(176, 138, 60, 0.35);
        }
        
        /* Search and Filter Bar */
        .lbi-directory-filters {
            background: #ffffff;
            border: 1px solid rgba(176, 138, 60, 0.15);
            border-radius: 12px;
            padding: 24px;
            margin: 0 auto 40px;
            max-width: 1200px;
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            align-items: center;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
        }
        
        .lbi-directory-search {
            flex: 1;
            min-width: 250px;
        }
        
        .lbi-directory-search input {
            width: 100%;
            padding: 12px 18px;
            border: 2px solid #e8e8e8;
            border-radius: 999px;
            font-size: 15px;
            transition: all 0.26s ease;
        }
        
        .lbi-directory-search input:focus {
            border-color: #b08a3c;
            box-shadow: 0 0 0 3px rgba(176, 138, 60, 0.1);
        }
        
        /* Interview Cards */
        .lbi-interview-card {
            background: #ffffff;
            border: 1px solid rgba(176, 138, 60, 0.12);
            border-radius: 16px;
            overflow: hidden;
            transition: all 0.34s cubic-bezier(0.22, 1, 0.36, 1);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
        }
        
        .lbi-interview-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 40px rgba(176, 138, 60, 0.15);
        }
        
        .lbi-interview-image {
            width: 100%;
            height: 220px;
            object-fit: cover;
            transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
        }
        
        .lbi-interview-card:hover .lbi-interview-image {
            transform: scale(1.05);
        }
        
        .lbi-interview-content {
            padding: 28px;
        }
        
        .lbi-interview-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: #111111;
            margin: 0 0 12px 0;
            line-height: 1.3;
        }
        
        .lbi-interview-title a {
            color: #111111;
            text-decoration: none;
            transition: color 0.26s ease;
        }
        
        .lbi-interview-title a:hover {
            color: #b08a3c;
        }
        
        /* Animations */
        @keyframes headerPulse {
            0%, 100% { transform: translateX(-50%) scale(1); opacity: 1; }
            50% { transform: translateX(-50%) scale(1.1); opacity: 0.8; }
        }
        
        @keyframes cardFadeIn {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .lbi-business-card,
        .lbi-interview-card {
            animation: cardFadeIn 0.6s ease-out backwards;
        }
        
        .lbi-business-card:nth-child(1),
        .lbi-interview-card:nth-child(1) { animation-delay: 0.05s; }
        .lbi-business-card:nth-child(2),
        .lbi-interview-card:nth-child(2) { animation-delay: 0.1s; }
        .lbi-business-card:nth-child(3),
        .lbi-interview-card:nth-child(3) { animation-delay: 0.15s; }
        .lbi-business-card:nth-child(4),
        .lbi-interview-card:nth-child(4) { animation-delay: 0.2s; }
        .lbi-business-card:nth-child(5),
        .lbi-interview-card:nth-child(5) { animation-delay: 0.25s; }
        .lbi-business-card:nth-child(6),
        .lbi-interview-card:nth-child(6) { animation-delay: 0.3s; }
        
        /* Mobile Responsiveness */
        @media (max-width: 768px) {
            .lbi-directory-header {
                padding: 60px 20px 40px;
            }
            
            .lbi-directory-grid {
                grid-template-columns: 1fr;
                gap: 24px;
                padding: 0 20px 60px;
            }
            
            .lbi-business-card {
                padding: 24px;
            }
            
            .lbi-directory-filters {
                padding: 16px;
            }
            
            .lbi-business-card:hover,
            .lbi-interview-card:hover {
                transform: none;
            }
        }
    </style>
    <?php
}
